<mxfile host="Electron" agent="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/28.2.5 Chrome/138.0.7204.251 Electron/37.6.1 Safari/537.36" version="28.2.5">
  <diagram name="Rheo Robot Control Flow" id="W_6I6GJ-zIgZVcbMgakN">
    <mxGraphModel dx="1193" dy="737" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="xMPiXxU-w79jIDbD8g35-110" value="Simplified Flow - Rheo Robot Control" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=24;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="800" height="40" as="geometry" />
        </mxCell>
        <mxCell id="xMPiXxU-w79jIDbD8g35-111" value="&lt;b&gt;1.&lt;/b&gt; User input&#xa;Voice or text&#xa;&#xa;Model: none (raw input)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="20" y="400" width="180" height="100" as="geometry" />
        </mxCell>
        <mxCell id="xMPiXxU-w79jIDbD8g35-112" value="&lt;b&gt;2.&lt;/b&gt; If voice:&#xa;Whisper converts audio to text&#xa;&#xa;Model: Whisper ASR&#xa;(VLM-Surgical-Agent-Framework, :43001)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=center" vertex="1" parent="1">
          <mxGeometry x="240" y="395" width="210" height="110" as="geometry" />
        </mxCell>
        <mxCell id="xMPiXxU-w79jIDbD8g35-113" value="&lt;b&gt;3.&lt;/b&gt; Operating Room Selector&#xa;chooses the right agent&#xa;&#xa;Model: Qwen2.5-VL-7B-Surg-CholecT50&#xa;(vLLM, served as surgical-vlm, :8000)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="490" y="370" width="250" height="160" as="geometry" />
        </mxCell>
        <mxCell id="xMPiXxU-w79jIDbD8g35-114" value="&lt;b&gt;4.&lt;/b&gt; Question / analysis&#xa;PeriOpChatAgent responds&#xa;Does NOT move the robot&#xa;&#xa;Model: Qwen2.5-VL-7B-Surg-CholecT50&#xa;(vLLM + WebRTC camera frame)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=center" vertex="1" parent="1">
          <mxGeometry x="470" y="120" width="290" height="150" as="geometry" />
        </mxCell>
        <mxCell id="xMPiXxU-w79jIDbD8g35-115" value="&lt;b&gt;5.&lt;/b&gt; Action command&#xa;UserCommandAgent prepares&#xa;a pending action&#xa;&#xa;Model: Qwen2.5-VL-7B-Surg-CholecT50&#xa;(vLLM, maps intent → policy sequence)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=center;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="470" y="620" width="290" height="120" as="geometry" />
        </mxCell>
        <mxCell id="xMPiXxU-w79jIDbD8g35-116" value="&lt;b&gt;6.&lt;/b&gt; Confirmation&#xa;user says: start / yes / go&#xa;&#xa;Model: none (user confirmation)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=center" vertex="1" parent="1">
          <mxGeometry x="800" y="395" width="200" height="110" as="geometry" />
        </mxCell>
        <mxCell id="xMPiXxU-w79jIDbD8g35-117" value="&lt;b&gt;7.&lt;/b&gt; RobotControlAgent&#xa;POST :8081/trigger&#xa;&#xa;Model: none (rule-based HTTP trigger)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="1050" y="395" width="210" height="110" as="geometry" />
        </mxCell>
        <mxCell id="xMPiXxU-w79jIDbD8g35-118" value="&lt;b&gt;8.&lt;/b&gt; triggered_policy_runner&#xa;receives trigger&#xa;&#xa;Model: none (orchestrator / policy loader)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=center" vertex="1" parent="1">
          <mxGeometry x="1320" y="395" width="240" height="110" as="geometry" />
        </mxCell>
        <mxCell id="xMPiXxU-w79jIDbD8g35-119" value="&lt;b&gt;9.&lt;/b&gt; GR00T Policy&#xa;robot executes in Isaac Sim&#xa;&#xa;Model: GR00T N1.6 VLA (Unitree G1 WBC)&#xa;• tray_pick_and_place → GR00T-N1.6-Rheo-PickNPlaceTray&#xa;• cart_push → GR00T-N1.6-Rheo-Sim-PushCart&#xa;Runtime: Isaac Sim + G1 whole-body control" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;align=left;spacingLeft=8" vertex="1" parent="1">
          <mxGeometry x="1230" y="600" width="350" height="170" as="geometry" />
        </mxCell>
        <mxCell id="xMPiXxU-w79jIDbD8g35-120" value="&lt;b&gt;A.&lt;/b&gt; Manual shortcut&#xa;curl / trigger_menu.sh&#xa;skips the agents&#xa;&#xa;Model: none (direct HTTP trigger)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;dashed=1;align=center" vertex="1" parent="1">
          <mxGeometry x="1000" y="610" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="xMPiXxU-w79jIDbD8g35-121" value="&lt;b&gt;Note.&lt;/b&gt; Current limitation:&#xa;vLLM (Qwen2.5-VL-7B) + Isaac Sim + GR00T N1.6&#xa;do not fit together in 32 GB VRAM.&#xa;That is why curl/menu is the reliable path&#xa;for robot control on a single GPU." style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#ffcccc;strokeColor=#b85450;align=left" vertex="1" parent="1">
          <mxGeometry x="810" y="120" width="330" height="150" as="geometry" />
        </mxCell>
        <mxCell id="xMPiXxU-w79jIDbD8g35-132" value="Background monitoring agents" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="20" y="745" width="300" height="25" as="geometry" />
        </mxCell>
        <mxCell id="xMPiXxU-w79jIDbD8g35-133" value="&lt;b&gt;10.&lt;/b&gt; PeriOpAnnotationAgent&#xa;continuously annotates OR frames&#xa;&#xa;Model: Qwen2.5-VL-7B&#xa;(vLLM + WebRTC image)&#xa;Output: structured annotations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=center;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="20" y="775" width="260" height="105" as="geometry" />
        </mxCell>
        <mxCell id="xMPiXxU-w79jIDbD8g35-134" value="&lt;b&gt;11.&lt;/b&gt; TrayPickNPlaceMonitorAgent&#xa;checks if surgical tray is missing&#xa;&#xa;Model: none&#xa;uses PeriOp annotations&#xa;Trigger: tray_pick_and_place" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=center;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="330" y="775" width="260" height="105" as="geometry" />
        </mxCell>
        <mxCell id="xMPiXxU-w79jIDbD8g35-135" value="&lt;b&gt;12.&lt;/b&gt; PushCartMonitorAgent&#xa;checks if tray is on the case cart&#xa;&#xa;Model: Qwen2.5-VL-7B&#xa;(vLLM + vision)&#xa;Trigger: cart_push" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=center;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="640" y="775" width="260" height="105" as="geometry" />

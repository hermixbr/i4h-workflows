        </mxCell>
        <mxCell id="eval_s2" value="&lt;b&gt;2. Aguardar ready&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Log: &quot;policy ready&quot;&lt;br&gt;Sem Traceback/Error&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;arcSize=10;" parent="1" vertex="1">
          <mxGeometry x="280" y="1155" width="170" height="70" as="geometry" />
        </mxCell>
        <mxCell id="eval_s3" value="&lt;b&gt;3. Arena rollout&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;arena/run.sh --env ENV&lt;br&gt;--episodes N --max-timesteps T&lt;br&gt;--record-to verify.hdf5&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;arcSize=10;" parent="1" vertex="1">
          <mxGeometry x="480" y="1155" width="210" height="70" as="geometry" />
        </mxCell>
        <mxCell id="eval_s4" value="&lt;b&gt;4. Loop episódio&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Obs (câmeras + estado) → Zenoh →&lt;br&gt;política → ações → sim&lt;br&gt;Critério de sucesso do env&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;arcSize=10;" parent="1" vertex="1">
          <mxGeometry x="720" y="1155" width="210" height="70" as="geometry" />
        </mxCell>
        <mxCell id="eval_s5" value="&lt;b&gt;5. Resultado&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Log: run complete: X/Y&lt;br&gt;episodes succeeded&lt;br&gt;→ taxa de sucesso&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;arcSize=10;" parent="1" vertex="1">
          <mxGeometry x="960" y="1155" width="120" height="70" as="geometry" />
        </mxCell>

          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eval_metrics" value="&lt;b&gt;Métricas e parâmetros&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;• &lt;b&gt;Taxa de sucesso:&lt;/b&gt; X/Y episódios no log da Arena&lt;br&gt;• &lt;b&gt;max-timesteps&lt;/b&gt; (YAML): scissor 500 · locomanip 1500 · ultrasound 250&lt;br&gt;• &lt;b&gt;Sanity check:&lt;/b&gt; 1 episódio, 200 steps&lt;br&gt;• &lt;b&gt;Avaliação real:&lt;/b&gt; 10–200+ episódios com max-timesteps do env&lt;br&gt;• &lt;b&gt;Saída:&lt;/b&gt; runs/eval_&amp;lt;env&amp;gt;_*/data/verify.hdf5&lt;br&gt;• &lt;b&gt;Logs:&lt;/b&gt; runs/eval_*/logs/policy.log + arena.log&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;arcSize=8;" parent="1" vertex="1">
          <mxGeometry x="60" y="1250" width="480" height="120" as="geometry" />
        </mxCell>
        <mxCell id="eval_optional" value="&lt;b&gt;Opcional — Annotator VLM&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;annotator/run.sh offline --hdf5-path verify.hdf5&lt;br&gt;Rotula sucesso por episódio com VLM (task description do YAML)&lt;br&gt;Útil quando o critério automático do sim não basta&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;arcSize=8;dashed=1;dashPattern=8 4;" parent="1" vertex="1">

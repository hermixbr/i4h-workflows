          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Eval details left -->
        <mxCell id="eval_metrics" value="&lt;b&gt;Metrics and parameters&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;• &lt;b&gt;Success rate:&lt;/b&gt; X/Y episodes in Arena log&lt;br&gt;• &lt;b&gt;max-timesteps&lt;/b&gt; (YAML): scissor 500 · locomanip 1500 · ultrasound 250&lt;br&gt;• &lt;b&gt;Sanity check:&lt;/b&gt; 1 episode, 200 steps&lt;br&gt;• &lt;b&gt;Full eval:&lt;/b&gt; 10–200+ episodes with env max-timesteps&lt;br&gt;• &lt;b&gt;Output:&lt;/b&gt; runs/eval_&amp;lt;env&amp;gt;_*/data/verify.hdf5&lt;br&gt;• &lt;b&gt;Logs:&lt;/b&gt; runs/eval_*/logs/policy.log + arena.log&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="1250" width="480" height="120" as="geometry" />
        </mxCell>

        <!-- Eval optional -->
        <mxCell id="eval_optional" value="&lt;b&gt;Optional — VLM Annotator&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;annotator/run.sh offline --hdf5-path verify.hdf5&lt;br&gt;Labels success per episode with VLM (YAML task description)&lt;br&gt;Useful when sim auto-criterion is not enough&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;arcSize=8;dashed=1;dashPattern=8 4;" vertex="1" parent="1">

        <mxCell id="env_desc_list" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;scissor_pick_and_place&lt;/b&gt;&lt;br&gt;Robot: SO-ARM 101 · GR00T N1.5&lt;br&gt;Task: pick scissors and place in tray&lt;br&gt;&lt;br&gt;&lt;b&gt;locomanip_tray_pick_and_place&lt;/b&gt;&lt;br&gt;Robot: Unitree G1 · GR00T N1.6&lt;br&gt;Task: pick box from shelf, turn 180°,&lt;br&gt;place on cart, return to initial posture&lt;br&gt;&lt;br&gt;&lt;b&gt;locomanip_push_cart&lt;/b&gt;&lt;br&gt;Robot: Unitree G1 · GR00T N1.6&lt;br&gt;Task: go to cart, grasp handles, push&lt;br&gt;to destination&lt;br&gt;&lt;br&gt;&lt;b&gt;ultrasound_liver_scan&lt;/b&gt;&lt;br&gt;Robot: Franka + probe · openpi PI0&lt;br&gt;Task: liver ultrasound on abdominal phantom&lt;br&gt;&lt;br&gt;&lt;b&gt;assemble_trocar&lt;/b&gt;&lt;br&gt;Robot: G1 + dex hands · GR00T N1.5&lt;br&gt;Task: assemble trocar from box&lt;br&gt;&lt;font color=&quot;#b85450&quot;&gt;⚠ inference-only (no agentic fine-tune)&lt;/font&gt;&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;" vertex="1" parent="1">

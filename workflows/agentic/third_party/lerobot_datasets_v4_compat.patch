+class _PyavVideoReader:
+    """Minimal stand-in for torchvision.io.VideoReader used when torchvision is
+    built without VideoReader support. Implements just enough of the iterator/seek
+    interface that ``decode_video_frames_torchvision`` exercises."""
+
+    def __init__(self, video_path: str):
+        import av
+
+        self.container = av.open(video_path)
+        self._stream = self.container.streams.video[0]
+        self._iter = None
+        self._last_seek_ts: float = 0.0
+
+    def seek(self, ts: float, keyframes_only: bool = True):  # noqa: ARG002
+        # av.seek expects an integer in stream time-base units.
+        tb = self._stream.time_base
+        target = int(max(ts, 0.0) / float(tb))
+        self.container.seek(target, any_frame=False, backward=True, stream=self._stream)
+        self._iter = self.container.decode(video=0)
+        self._last_seek_ts = ts
+
+    def __iter__(self):
+        if self._iter is None:
+            self._iter = self.container.decode(video=0)
+        return self
+
+    def __next__(self):
+        if self._iter is None:
+            self._iter = self.container.decode(video=0)
+        frame = next(self._iter)
+        # Torchvision returns dict with "pts" (seconds, float) and "data" (CHW uint8 tensor).
+        pts = float(frame.pts * frame.time_base) if frame.pts is not None else self._last_seek_ts
+        # Convert to CHW uint8 tensor.
+        import numpy as np
+        arr = frame.to_ndarray(format="rgb24")  # HWC uint8
+        data = torch.from_numpy(np.ascontiguousarray(arr)).permute(2, 0, 1)  # CHW
+        return {"pts": pts, "data": data}
+
+

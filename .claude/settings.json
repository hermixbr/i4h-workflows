{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "sandbox": {
    "excludedCommands": ["*agentic*"]
  },
  "permissions": {
    "allow": [
      "Edit(./.claude/skills/**)",
      "Bash(.claude/skills/i4h-*/scripts/*.sh*)",
      "Bash(workflows/agentic/*.sh*)",
      "Bash(./workflows/agentic/*.sh*)",
      "Bash(workflows/agentic/**/*.sh*)",
      "Bash(./workflows/agentic/**/*.sh*)"
    ]
  },
  "enableAllProjectMcpServers": true
}
